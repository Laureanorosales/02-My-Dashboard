# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js Build and Output
/.next/
/out/
/build
html/

# Production & Build info
*.tsbuildinfo
next-env.d.ts

# Testing & Coverage
/coverage
/.nyc_output
.jest/

# Debug and Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
yarn-error.log

# Environment variables (Crucial: never commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.local

# Allow committing .env.example if it exists
!.env.example

# Operating System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.pem

# IDEs and Editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vercel & Deployments
.vercel

